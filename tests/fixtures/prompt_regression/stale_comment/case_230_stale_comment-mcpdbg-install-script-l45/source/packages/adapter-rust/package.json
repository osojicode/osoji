{
  "name": "@debugmcp/adapter-rust",
  "version": "0.22.0",
  "description": "Rust debug adapter for MCP Debugger using CodeLLDB",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "vendor"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:ci": "tsc -p tsconfig.json",
    "build:adapter": "node scripts/vendor-codelldb.js",
    "clean": "rimraf dist vendor",
    "clean:vendor": "rimraf vendor",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@debugmcp/shared": "workspace:*",
    "@vscode/debugprotocol": "^1.68.0",
    "which": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/which": "^3.0.4",
    "extract-zip": "^2.0.1",
    "progress": "^2.0.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
