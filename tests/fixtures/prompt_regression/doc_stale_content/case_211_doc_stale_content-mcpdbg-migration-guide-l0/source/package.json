{
  "name": "mcp-debugger-monorepo",
  "private": true,
  "version": "0.23.0",
  "description": "Run-time step-through debugging for LLM agents - Monorepo root",
  "homepage": "https://github.com/debugmcp/mcp-debugger",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/debugmcp/mcp-debugger.git"
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "nohoist": [
      "**/debugpy",
      "**/node-inspector"
    ]
  },
  "scripts": {
    "prepare": "husky",
    "postinstall": "pnpm run vendor:adapters",
    "vendor": "pnpm run vendor:adapters",
    "vendor:adapters": "pnpm run -r --if-present build:adapter",
    "vendor:force": "pnpm run clean:vendor && pnpm run vendor:adapters",
    "vendor:status": "node scripts/check-adapters.js",
    "clean:vendor": "pnpm run -r --if-present clean:vendor",
    "prebuild": "node scripts/clean-src-artifacts.cjs && rimraf dist && pnpm run vendor:adapters",
    "build": "pnpm run build:packages && tsc -b -f . && pnpm run postbuild && pnpm run bundle",
    "build:shared": "pnpm --filter @debugmcp/shared build",
    "build:adapters": "pnpm --filter @debugmcp/adapter-mock build && pnpm --filter @debugmcp/adapter-python build && pnpm --filter @debugmcp/adapter-ruby build",
    "build:adapters:all": "pnpm --filter @debugmcp/adapter-mock build && pnpm --filter @debugmcp/adapter-python build && pnpm --filter @debugmcp/adapter-ruby build && pnpm --filter @debugmcp/adapter-javascript build",
    "dev:js": "pnpm -w -F @debugmcp/adapter-javascript build && pnpm -w -F @debugmcp/adapter-javascript run build:adapter",
    "build:packages": "node scripts/build-packages.cjs",
    "build:packages:ci": "cross-env BUILD_SCRIPT=build:ci node scripts/build-packages.cjs",
    "build:ci": "node scripts/clean-src-artifacts.cjs && rimraf dist && pnpm run build:packages:ci && tsc -b -f . && pnpm run postbuild",
    "build:servercore": "tsc -p tsconfig.json",
    "build:all": "pnpm -r build && pnpm run build",
    "build:clean": "pnpm run clean && pnpm run build",
    "start": "node dist/index.js",
    "dev": "ts-node-esm src/index.ts",
    "docker-build": "docker build . -t mcp-debugger:local",
    "pretest:docker": "node scripts/docker-build-if-needed.js",
    "test": "pnpm run build && pnpm run pretest:docker && vitest run",
    "posttest": "node scripts/cleanup-test-processes.js",
    "test:watch": "vitest watch",
    "posttest:watch": "node scripts/cleanup-test-processes.js",
    "test:unit": "vitest run --project unit",
    "posttest:unit": "node scripts/cleanup-test-processes.js",
    "test:strict": "cross-env LEAK_GUARD_STRICT=1 vitest run --project unit --project integration",
    "posttest:strict": "node scripts/cleanup-test-processes.js",
    "test:flake": "node scripts/flake-hunt.mjs",
    "posttest:flake": "node scripts/cleanup-test-processes.js",
    "test:integration": "vitest run --project integration",
    "posttest:integration": "node scripts/cleanup-test-processes.js",
    "test:e2e": "pnpm run pretest:docker && vitest run --project e2e",
    "pretest:e2e": "pnpm run build",
    "posttest:e2e": "node scripts/cleanup-test-processes.js",
    "test:no-python": "cross-env SKIP_PYTHON_TESTS=true pnpm test",
    "test:no-docker": "cross-env SKIP_DOCKER_TESTS=true pnpm test",
    "test:ci": "pnpm run test:no-docker",
    "test:ci-no-python": "pnpm run build && vitest run --project unit",
    "test:ci-coverage": "pnpm run build && vitest run --coverage --project unit --project integration",
    "test:core": "vitest run tests/core",
    "posttest:core": "node scripts/cleanup-test-processes.js",
    "test:python": "vitest run tests/adapters/python",
    "posttest:python": "node scripts/cleanup-test-processes.js",
    "pretest:e2e:smoke": "pnpm run build",
    "test:e2e:smoke": "vitest run tests/e2e/mcp-server-smoke",
    "test:e2e:container": "docker build --no-cache -t mcp-debugger:local . && vitest run tests/e2e/docker/",
    "pretest:e2e:npx": "pnpm run build",
    "test:e2e:npx": "vitest run tests/e2e/npx",
    "test:all-channels": "pnpm test:e2e:smoke && pnpm test:e2e:container && pnpm test:e2e:npx",
    "test:docker-e2e": "cross-env DOCKER_E2E=1 vitest run tests/e2e/docker/docker-proxy-liveness.test.ts",
    "test:stress": "cross-env RUN_STRESS_TESTS=true vitest run --project integration tests/stress",
    "pretest:coverage": "pnpm run build && pnpm run pretest:docker && node scripts/clean-coverage.js",
    "test:coverage": "vitest run --coverage",
    "posttest:coverage": "node scripts/cleanup-test-processes.js && node analyze-coverage.js",
    "test:coverage:quiet": "vitest run --coverage --reporter=dot --silent",
    "posttest:coverage:quiet": "node scripts/cleanup-test-processes.js",
    "test:coverage:summary": "node tests/test-utils/helpers/test-coverage-summary.js",
    "test:coverage:analyze": "node analyze-coverage-detailed.js",
    "coverage:analyze": "pnpm run test:coverage && node analyze-coverage-detailed.js",
    "test:coverage:json": "pnpm run build && vitest run --coverage --reporter=json --outputFile=test-results.json",
    "posttest:coverage:json": "node scripts/cleanup-test-processes.js",
    "test:dot": "vitest run --reporter=dot",
    "posttest:dot": "node scripts/cleanup-test-processes.js",
    "test:json": "vitest run --reporter=json --outputFile=test-results.json",
    "posttest:json": "node scripts/cleanup-test-processes.js",
    "test:failures": "node tests/test-utils/helpers/show-failures.js",
    "test:summary": "node tests/test-utils/helpers/test-summary.js",
    "test:quiet": "vitest run --reporter=dot --silent",
    "posttest:quiet": "node scripts/cleanup-test-processes.js",
    "test:verbose": "vitest run --reporter=verbose",
    "posttest:verbose": "node scripts/cleanup-test-processes.js",
    "lint": "eslint \"src/**/*.ts\" \"packages/*/src/**/*.ts\" \"scripts/**/*.{js,mjs,cjs}\"",
    "lint:fix": "eslint src/**/*.ts --fix",
    "check:personal-paths": "node scripts/check-personal-paths.cjs",
    "check:all-personal-paths": "node scripts/check-all-personal-paths.cjs",
    "commit:safe": "scripts/safe-commit.sh",
    "commit:fast": "scripts/safe-commit.sh --skip-tests",
    "bundle": "pnpm --filter @debugmcp/mcp-debugger run build",
    "postbuild": "node scripts/copy-proxy-files.cjs",
    "clean": "rimraf dist",
    "act:check": "scripts\\act-runner.cmd --version",
    "act:lint": "scripts\\act-runner.cmd -j lint",
    "act:test": "scripts\\act-runner.cmd -W .github/workflows/ci.yml -j build-and-test --matrix os:ubuntu-latest",
    "act:test:all": "scripts\\act-runner.cmd -j build-and-test",
    "act:full": "scripts\\act-runner.cmd",
    "act:list": "scripts\\act-runner.cmd -l",
    "act:debug": "scripts\\act-runner.cmd -j build-and-test --verbose",
    "validate": "node scripts/validate-push.js",
    "validate:quick": "node scripts/validate-push.js --no-tests",
    "validate:smoke": "node scripts/validate-push.js --smoke",
    "dev:proxy": "node tools/dev-proxy/dev-proxy.mjs",
    "release:dry-run": "bash scripts/release-dry-run.sh"
  },
  "keywords": [
    "mcp",
    "dap",
    "debugger",
    "debugging",
    "llm",
    "ai-agent",
    "debugpy",
    "step-through",
    "python"
  ],
  "author": "debugmcp <debug@sycamore.llc>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/debugmcp/mcp-debugger/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "mcp-debugger": "./dist/index.js"
  },
  "dependencies": {
    "@debugmcp/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/which": "^3.0.4",
    "@vscode/debugprotocol": "^1.68.0",
    "commander": "^15.0.0",
    "debug": "^4.4.3",
    "eventsource": "^4.1.0",
    "express": "^5.2.1",
    "fs-extra": "^11.3.6",
    "lru-cache": "^11.5.2",
    "uuid": "^14.0.1",
    "which": "^7.0.0",
    "winston": "^3.19.0"
  },
  "optionalDependencies": {
    "@debugmcp/adapter-dotnet": "workspace:*",
    "@debugmcp/adapter-go": "workspace:*",
    "@debugmcp/adapter-java": "workspace:*",
    "@debugmcp/adapter-javascript": "workspace:*",
    "@debugmcp/adapter-mock": "workspace:*",
    "@debugmcp/adapter-python": "workspace:*",
    "@debugmcp/adapter-ruby": "workspace:*",
    "@debugmcp/adapter-rust": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/debug": "^4.1.13",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^26.1.1",
    "@vitest/coverage-istanbul": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "c8": "^11.0.0",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "fast-check": "^4.9.0",
    "glob": "^13.0.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "vite": "7.3.6",
      "path-to-regexp": ">=8.4.0",
      "brace-expansion": ">=5.0.6",
      "hono": "^4.12.25",
      "fast-uri": "^3.1.2",
      "qs": "^6.15.2",
      "ip-address": "^10.1.1",
      "esbuild": "^0.28.1"
    }
  }
}
