  },
  "engines": {
    "node": ">=22.0.0"
  },
  "peerDependencies": {
    "@debugmcp/shared": "0.22.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/debugmcp/mcp-debugger.git",
    "directory": "packages/adapter-ruby"
