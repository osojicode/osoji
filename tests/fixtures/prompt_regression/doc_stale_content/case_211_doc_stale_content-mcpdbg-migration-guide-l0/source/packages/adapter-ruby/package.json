{
  "name": "@debugmcp/adapter-ruby",
  "version": "0.22.0",
  "description": "Ruby debug adapter for MCP debugger using rdbg",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "build:ci": "tsc -b -f",
