# CI tooling. Pinned and hash-locked in requirements-tools.lock so that
# pip-audit, uv, and build are never installed from PyPI without hash
# verification. Edit this file and regenerate the lock via:
#   uv pip compile requirements-tools.in --generate-hashes --universal -o requirements-tools.lock
pip-audit==2.10.0
uv==0.11.8
build==1.4.4
